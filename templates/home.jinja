<!DOCTYPE html>
<html lang="en" data-palette="copper" data-mode="light" data-typography="technical">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ site.title }}</title>
    <meta name="description" content="Thoughts on programming, type systems, and software engineering">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fira+Code:wght@400;500&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:wght@400;500;600;700&family=Inconsolata:wght@400;500&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600;700&family=Karla:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Libre+Franklin:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Nunito+Sans:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Roboto+Mono:wght@400;500&family=Source+Code+Pro:wght@400;500&family=Source+Sans+3:wght@400;500;600;700&family=Syne:wght@400;500;600;700;800&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% if assets.css_path %}<link rel="stylesheet" href="{{ assets.css_path }}">{% endif %}
    <link rel="canonical" href="{{ site.base_url }}{{ page.url }}">
    <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.base_path }}/feed.xml">
    <script>
      (function(){var d=document.documentElement,g=function(k,f){return localStorage.getItem(k)||f};d.setAttribute('data-palette',g('palette','copper'));d.setAttribute('data-typography',g('typography','technical'));var m=localStorage.getItem('mode');if(!m)m=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';d.setAttribute('data-mode',m)})();
    </script>
</head>
<body>
    <header class="site-header">
        <div class="container">
            <div class="site-title"><a href="{{ site.base_path }}/">{{ site.title }}</a></div>
            <nav class="site-nav">
                <a href="{{ site.base_path }}/">Posts</a>
                <a href="{{ site.base_path }}/projects/">Projects</a>
                <a href="{{ site.base_path }}/about/">About</a>
                <a href="{{ site.base_path }}/tags/">Tags</a>
                <a href="{{ site.base_path }}/feed.xml">RSS</a>
                <div class="theme-controls">
                    <select class="palette-select" aria-label="Color palette">
                        <option value="obsidian">Obsidian</option>
                        <option value="ocean">Ocean</option>
                        <option value="forest">Forest</option>
                        <option value="rose">Rose</option>
                        <option value="violet">Violet</option>
                        <option value="copper">Copper</option>
                        <option value="arctic">Arctic</option>
                        <option value="noir">Noir</option>
                    </select>
                    <select class="typography-select" aria-label="Typography">
                        <option value="editorial">Editorial</option>
                        <option value="humanist">Humanist</option>
                        <option value="technical">Technical</option>
                        <option value="elegant">Elegant</option>
                        <option value="geometric">Geometric</option>
                        <option value="brutalist">Brutalist</option>
                        <option value="vintage">Vintage</option>
                        <option value="swiss">Swiss</option>
                    </select>
                    <button class="mode-toggle" aria-label="Toggle dark/light mode"></button>
                </div>
            </nav>
        </div>
    </header>
    <main class="container">
        <div class="hero">
            <h1>Opining on Tech</h1>
            <p>Thoughts on programming, type systems, and software engineering.</p>
        </div>
        <h2 class="section-heading">Recent Posts</h2>
        {% set all_pages = get_pages() %}
        {% if all_pages %}
        <ul class="post-list">
            {% for p in all_pages %}
            {% if "/posts/" in p.url and p.date %}
            <li class="post-item">
                <span class="post-date">{{ p.date }}</span>
                <span class="post-title"><a href="{{ p.url }}">{{ p.title }}</a></span>
            </li>
            {% endif %}
            {% endfor %}
        </ul>
        {% endif %}
    </main>
    <footer class="site-footer">
        <div class="container">
            <p><a href="/">Home</a></p>
            <p>&copy; {{ now() | date(format="%Y") }} Josh Burgess</p>
        </div>
    </footer>
    {% if assets.js_path %}<script src="{{ assets.js_path }}"></script>{% endif %}
</body>
</html>
 
